    "152": {
      "name": "Chile",
      "status": "distinct",
      "legislation": "Ministry of Agriculture, SAG. Draft Resolution on NBTs (open for public consultation, January 2026)",
      "legislation_url": "https://www.sag.gob.cl/sites/default/files/Proyecto-Resolucion-NBT-Consulta-Publica.pdf",
      "year_established": 2017,
      "regulatory_body": "Servicio Agrícola y Ganadero (SAG)",
      "summary": "Chile has operated an informal case-by-case evaluation procedure since 2017 under Resolution No. 1523/2001. A draft resolution published for public consultation on 7 January 2026 would formalise this as a mandatory administrative process with a defined 20 working-day determination timeline. The draft explicitly excludes insertions of alleles from the same species from the definition of 'new combination of genetic material'. As of May 2026, the draft has not yet entered into force, pending publication in the Diario Oficial.",
      "approach": "Informal case-by-case procedure pending formalisation. Based on whether product contains a new combination of genetic material.",
      "further_reading_url": "https://cropgeregulations.com/locations/south-america/"
    },
