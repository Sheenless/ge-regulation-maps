    "218": {
      "name": "Ecuador",
      "status": "distinct",
      "legislation": "Ministry of Agriculture, Livestock, and Fisheries. Ministerial Agreement No. 063/2023",
      "legislation_url": "http://servicios.agricultura.gob.ec/mag01/pdfs/aministerial/2023/063-2023_acuerdo_ministerial_guia_tecnica_edicion_genetica_vf_numerado-signed.pdf",
      "year_established": 2023,
      "regulatory_body": "Ministry of Agriculture, Livestock, and Fisheries (MAGAP)",
      "summary": "Ecuador operates within a constrained framework — Article 401 of the 2008 Constitution declares Ecuador a GMO-free country. However, Ministerial Agreement No. 063/2023 established that only organisms containing recombinant or foreign DNA qualify as GMOs, creating a definitional exemption for transgene-free gene-edited products. The first application under this framework was submitted in October 2024 for a gene-edited banana variety developed in response to Fusarium wilt TR4 pressure.",
      "approach": "Definitional exclusion. Transgene-free gene-edited products fall outside the GMO definition under the Organic Code of the Environment (2019), without overriding the constitutional prohibition.",
      "further_reading_url": "https://cropgeregulations.com/locations/south-america/"
    },
