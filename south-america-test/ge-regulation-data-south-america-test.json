    "032": {
      "name": "Argentina",
      "status": "distinct",
      "legislation": "Ministry of Economy, Secretariat of Agriculture, Livestock and Fisheries. Resolution No. 24/2026",
      "legislation_url": "https://www.magyp.gob.ar/sitio/areas/biotecnologia/conabia/marco_regulatorio_nbt.php",
      "year_established": 2015,
      "regulatory_body": "Argentine Biosafety Commission (CONABIA)",
      "summary": "Argentina was the first country in the world to establish a regulatory framework specifically for gene-edited crops, through Decision 173/2015. Gene-edited products without foreign DNA are classified as conventional and exempt from GMO regulation. This product-based, foreign-DNA criterion has become an international regulatory standard — the 'Argentina model'.",
      "approach": "Product-based, case-by-case. Developers submit a dossier to CONABIA, which determines whether the product contains stable foreign DNA.",
      "further_reading_url": "https://cropgeregulations.com/argentinas-updated-approach-to-new-breeding-techniques/"
    },
