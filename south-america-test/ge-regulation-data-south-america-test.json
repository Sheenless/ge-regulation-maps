    },
    "604": {
      "name": "Peru",
      "status": "distinct",
      "legislation": "Ministry of Environment. Ministerial Resolution No. D000068-2026-MINAM-DM",
      "legislation_url": "https://www.gob.pe/institucion/minam/normas-legales/7834313-d000068-2026-minam-dm",
      "year_established": 2026,
      "regulatory_body": "Ministry of the Environment (MINAM)",
      "summary": "Peru's situation is distinctive due to the coexistence of a new GE classification framework with an active GMO moratorium. Law 29811 (2011), extended by Law 31111 to 31 December 2035, maintains a moratorium on Living Modified Organisms. Within this, MINAM approved Ministerial Resolution No. D000068-2026-MINAM-DM on 8 March 2026, establishing criteria to determine whether NBT-derived products fall within the scope of the moratorium. Transgene-free gene-edited products that do not meet the LMO definition may be classified as conventional.",
      "approach": "Definitional exclusion operating within an active GMO moratorium. Transgene-free products may be classified as conventional under criteria established March 2026.",
      "further_reading_url": "https://cropgeregulations.com/locations/south-america/"
    },
