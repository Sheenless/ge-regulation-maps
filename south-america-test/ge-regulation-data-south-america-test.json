    "076": {
      "name": "Brazil",
      "status": "distinct",
      "legislation": "Ministry of Science, Technology, Innovation, and Communications. Normative Resolution CTNBio No. 16/2018",
      "legislation_url": "https://in.gov.br/en/web/dou/-/resolucao-normativa-n-16-de-15-de-janeiro-de-2018-2020545",
      "year_established": 2018,
      "regulatory_body": "National Technical Commission on Biosafety (CTNBio)",
      "summary": "CTNBio established a framework for gene-edited crops through Normative Resolution No. 16 (RN16), issued 15 January 2018. RN16 defines 'Innovative Precision Improvement Techniques' (TIMPs) and allows developers to seek a determination on GMO classification. Products without recombinant DNA/RNA in the final product are eligible for non-GMO classification. In December 2024, MARA issued five biosafety certificates for gene-edited events, including the first gene-edited rice event approved for domestic cultivation.",
      "approach": "Product-based, consultation procedure. Products without recombinant DNA/RNA in the final product are classified as conventional.",
      "further_reading_url": "https://cropgeregulations.com/locations/south-america/"
