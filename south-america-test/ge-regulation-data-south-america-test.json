    "600": {
      "name": "Paraguay",
      "status": "distinct",
      "legislation": "Ministry of Agriculture and Livestock. Resolution No. 842/2019",
      "legislation_url": "https://conbio.mag.gov.py/media/ckfinder/files/RES.N842%2010%20DE%20JULIO%20DE%202019%20NBT.pdf",
      "year_established": 2019,
      "regulatory_body": "National Commission on Agricultural and Forestry Biosafety (CONBIO)",
      "summary": "Paraguay established its gene editing regulatory framework in 2019 through CONBIO Resolution No. 842. Classification is determined on a case-by-case basis according to whether the final product contains foreign DNA. Paraguay was among the earlier Latin American adopters of a GE-specific regulatory pathway, following Argentina, Brazil, and Chile.",
